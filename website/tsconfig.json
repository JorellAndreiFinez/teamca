{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,

    "baseUrl": "src",
    "ignoreDeprecations": "6.0",

    "paths": {
      "@/*": ["*"]
    }
  },
  "include": ["src/**/*"]
}
