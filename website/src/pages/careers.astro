---
import "@/styles/global.css";
import MainLayout from '@/layouts/MainLayout.tsx';
import CareersHero from '@/components/hero/CareersHero.tsx';
import FinancialAdvisors from "@/components/sections/careers/FinancialAdvisors";
import Interns from "@/components/sections/careers/Interns";

---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#ac1212" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/icons/teamca-white-circle-logo.png" />
    <title>Careers | Team CA</title>
  </head>
  <body>
    <MainLayout client:load>
      <CareersHero client:load />
      <FinancialAdvisors client:load />
      <Interns client:load />


    </MainLayout>
  </body>
</html>
