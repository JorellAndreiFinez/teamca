---
import "../styles/globals.css";
import Sidebar from "../components/common/Sidebar";
import SocketInitializer from "../components/SocketInitializer";
import { ViewTransitions } from "astro:transitions";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TeamCA</title>
    <ViewTransitions />
    <script>
      // Client-side auth guard
      const stored = localStorage.getItem("auth-storage");
      if (!stored) {
        window.location.replace("/login");
      } else {
        try {
          const parsed = JSON.parse(stored);
          const hasToken = Boolean(parsed?.state?.token);
          const hasUser = Boolean(parsed?.state?.user);
          if (!hasToken || !hasUser) {
            window.location.replace("/login");
          }
        } catch {
          window.location.replace("/login");
        }
      }
    </script>
  </head>
  <body class="bg-slate-50 min-h-screen">
    <!-- Socket Initializer -->
    <SocketInitializer client:load />

    <!-- Sidebar -->
    <Sidebar client:load />

    <!-- Main content area with offset for sidebar -->
    <div id="main-content" class="transition-all duration-300 ml-64">
      <main class="min-h-screen p-6">
        <slot />
      </main>
    </div>
  </body>
</html>
