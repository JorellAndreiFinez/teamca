---
import "../styles/globals.css";
import Sidebar from "../components/common/Sidebar";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>TeamCA</title>
    <script>
      // Client-side auth guard
      const stored = localStorage.getItem("auth-storage");
      if (!stored) {
        window.location.replace("/login");
      } else {
        try {
          const parsed = JSON.parse(stored);
          const hasToken = Boolean(parsed?.state?.token);
          const hasUser = Boolean(parsed?.state?.user);

          if (!hasToken || !hasUser) {
            window.location.replace("/login");
          }
        } catch {
          window.location.replace("/login");
        }
      }
    </script>
  </head>
  <body class="bg-gray-50 min-h-screen">
    <!-- Sidebar -->
    <Sidebar client:load />

    <!-- Main content area with offset for sidebar -->
    <div id="main-content" class="transition-all duration-300 ml-64">
      <main class="min-h-screen p-6">
        <slot />
      </main>
    </div>

    <script>
      // Dynamically adjust main content margin when sidebar collapses
      // TODO: listen for sidebar collapse events and update #main-content margin
    </script>
  </body>
</html>
